@model LoginViewModel
@{
    ViewData["Title"] = "Login";
    var participants = ViewBag.Participants as IEnumerable<Participant> ?? [];
    var administrators = ViewBag.Administrators as IEnumerable<Administrator> ?? [];
}

<link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />

<section class="auth">
    <span class="auth-eyebrow">Sign in</span>
    <h1 class="auth-title">Log in to CEMS</h1>
    <p class="auth-lede">
        This is a demo, session-based login &mdash; no password required.
        Enter a person ID below, or pick an account from the registers.
    </p>

    <div class="auth-card">
        <div class="auth-card-label">Sign in with a person ID</div>
        <div asp-validation-summary="ModelOnly" class="auth-error"></div>
        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <div class="auth-form-row">
                <div class="form-group">
                    <label asp-for="PersonId"></label>
                    <input asp-for="PersonId" class="form-control" autocomplete="off" />
                    <span asp-validation-for="PersonId" class="auth-field-error"></span>
                </div>
                <button type="submit" class="btn btn-primary">Sign in</button>
            </div>
        </form>
    </div>

    <div class="auth-divider">or continue as</div>

    <div class="auth-registers">
        <div>
            <div class="auth-register-heading">
                <span>Participants</span>
                <span class="role-badge">Participant</span>
            </div>
            @if (!participants.Any())
            {
                <p class="account-empty">No participant accounts yet.</p>
            }
            else
            {
                @foreach (var p in participants)
                {
                    <form asp-action="Login" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="PersonId" value="@p.PersonId" />
                        <button type="submit" class="account-row">
                            <span class="account-name">@p.Name</span>
                            <span class="account-id">ID @p.PersonId</span>
                        </button>
                    </form>
                }
            }
        </div>
        <div>
            <div class="auth-register-heading">
                <span>Administrators</span>
                <span class="role-badge">Administrator</span>
            </div>
            @if (!administrators.Any())
            {
                <p class="account-empty">No administrator accounts yet.</p>
            }
            else
            {
                @foreach (var a in administrators)
                {
                    <form asp-action="Login" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="PersonId" value="@a.PersonId" />
                        <button type="submit" class="account-row">
                            <span class="account-name">@a.Name</span>
                            <span class="account-id">ID @a.PersonId</span>
                        </button>
                    </form>
                }
            }
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
