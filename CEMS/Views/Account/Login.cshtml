@model LoginViewModel
@{
    ViewData["Title"] = "Login";
    var participants = ViewBag.Participants as IEnumerable<Participant> ?? [];
    var administrators = ViewBag.Administrators as IEnumerable<Administrator> ?? [];
    var signup = ViewBag.Signup as SignupViewModel ?? new SignupViewModel();
    var activeTabIsAdmin = ViewBag.ActiveTab as string == "admin";
    var showSignupForm = ViewBag.ShowSignupForm is true;
}

<link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />

<section class="auth">
    <span class="auth-eyebrow">Sign in</span>
    <h1 class="auth-title">Log in to CEMS</h1>
    <p class="auth-lede">
        This is a demo, session-based login &mdash; no password required.
        Enter a person ID below, or pick an account from the tabs, or create a new participant account.
    </p>

    <div class="auth-card">
        <div class="auth-card-label">Sign in with a person ID</div>
        <div asp-validation-summary="ModelOnly" class="auth-error"></div>
        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <div class="auth-form-row">
                <div class="form-group">
                    <label asp-for="PersonId"></label>
                    <input asp-for="PersonId" class="form-control" autocomplete="off" placeholder="e.g. 1" min="1"
                           value="@(Model.PersonId == 0 ? null : Model.PersonId.ToString())" />
                    <span asp-validation-for="PersonId" class="auth-field-error"></span>
                </div>
                <button type="submit" class="btn btn-primary">Sign in</button>
            </div>
        </form>
    </div>

    <div class="auth-divider">or continue as</div>

    <div class="auth-tabs">
        <input type="radio" name="account-tab" id="tab-participant" class="auth-tab-input" @(activeTabIsAdmin ? "" : "checked") />
        <input type="radio" name="account-tab" id="tab-admin" class="auth-tab-input" @(activeTabIsAdmin ? "checked" : "") />

        <div class="auth-tab-list">
            <label for="tab-participant" class="auth-tab">Participant</label>
            <label for="tab-admin" class="auth-tab">Admin</label>
        </div>

        <div class="auth-tab-panel auth-tab-panel--participant">
            <p class="registry-heading">Existing accounts</p>
            @if (!participants.Any())
            {
                <p class="registry-empty">No participant accounts yet.</p>
            }
            else
            {
                <form asp-action="Login" method="post" class="auth-account-list">
                    @Html.AntiForgeryToken()
                    @foreach (var p in participants)
                    {
                        <button type="submit" name="PersonId" value="@p.PersonId" class="registry-entry auth-account-entry">
                            <span class="registry-tag">ID @p.PersonId</span>
                            <div class="registry-body">
                                <h3>@p.Name</h3>
                                <p>@p.Email</p>
                            </div>
                        </button>
                    }
                </form>
            }

            <details class="auth-signup" @(showSignupForm ? "open" : "")>
                <summary>New here? Create an account</summary>
                <form asp-action="Signup" method="post" class="auth-signup-form">
                    @Html.AntiForgeryToken()
                    @Html.ValidationMessage("Signup", new { @class = "form-error-summary" })
                    <div class="form-group">
                        <label for="signup-name">Full name</label>
                        <input id="signup-name" name="Name" value="@signup.Name" class="form-control" autocomplete="name" />
                        @Html.ValidationMessage("Name", new { @class = "field-error" })
                    </div>
                    <div class="form-group">
                        <label for="signup-email">Email</label>
                        <input id="signup-email" name="Email" type="email" value="@signup.Email" class="form-control" autocomplete="email" />
                        @Html.ValidationMessage("Email", new { @class = "field-error" })
                    </div>
                    <div class="form-group">
                        <label for="signup-phone">Phone (optional)</label>
                        <input id="signup-phone" name="Phone" value="@signup.Phone" class="form-control" autocomplete="tel" />
                        @Html.ValidationMessage("Phone", new { @class = "field-error" })
                    </div>
                    <button type="submit" class="btn btn-primary">Create account &amp; sign in</button>
                </form>
            </details>
        </div>

        <div class="auth-tab-panel auth-tab-panel--admin">
            <p class="registry-heading">Existing accounts</p>
            @if (!administrators.Any())
            {
                <p class="registry-empty">No administrator accounts yet.</p>
            }
            else
            {
                <form asp-action="Login" method="post" class="auth-account-list">
                    @Html.AntiForgeryToken()
                    @foreach (var a in administrators)
                    {
                        <button type="submit" name="PersonId" value="@a.PersonId" class="registry-entry auth-account-entry">
                            <span class="registry-tag">ID @a.PersonId</span>
                            <div class="registry-body">
                                <h3>@a.Name</h3>
                                <p>@a.Email</p>
                            </div>
                        </button>
                    }
                </form>
            }
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
