@model ActivityFormViewModel
@{
    ViewData["Title"] = "Edit Activity";
}
<h2>Edit Activity</h2>
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="ActivityId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger"></span></div>
    <div class="mb-3"><label asp-for="Type" class="form-label"></label><input asp-for="Type" class="form-control" /><span asp-validation-for="Type" class="text-danger"></span></div>
    <div class="mb-3"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control"></textarea><span asp-validation-for="Description" class="text-danger"></span></div>
    <button type="submit" class="btn btn-primary">Update</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
