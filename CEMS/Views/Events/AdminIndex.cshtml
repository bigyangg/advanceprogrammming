@model IEnumerable<Event>
@{
    ViewData["Title"] = "Manage Events";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Manage Events</h2>
    <a asp-action="Create" class="btn btn-primary">Create Event</a>
</div>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Date</th>
            <th>Venues</th>
            <th>Activities</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.EventDate</td>
                <td>@string.Join(", ", item.Venues.Select(v => v.Name))</td>
                <td>@string.Join(", ", item.Activities.Select(a => a.Name))</td>
                <td class="d-flex gap-2">
                    <a asp-action="Details" asp-route-id="@item.EventId" class="btn btn-sm btn-outline-primary">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.EventId" class="btn btn-sm btn-outline-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.EventId" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
