@model EventFormViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Create Event";
}

<link rel="stylesheet" href="~/css/events.css" asp-append-version="true" />

<div class="page-header">
    <span class="page-eyebrow">Admin</span>
    <h1>Create Event</h1>
    <p>Set the details, then assign the venues and activities that make it up.</p>
</div>

<div class="event-form-shell">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="form-error-summary"></div>

        <div class="form-section">
            <div class="form-section-head">
                <span class="form-section-eyebrow">01 — Details</span>
                <h2>What's happening</h2>
            </div>
            <div class="form-group">
                <label asp-for="Name"></label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Tech Connect 2026" />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Description"></label>
                <textarea asp-for="Description" class="form-control" rows="4" placeholder="What should participants expect?"></textarea>
                <span asp-validation-for="Description" class="field-error"></span>
            </div>
        </div>

        <div class="form-section">
            <div class="form-section-head">
                <span class="form-section-eyebrow">02 — Schedule &amp; capacity</span>
                <h2>When &amp; how many</h2>
            </div>
            <div class="form-row-2">
                <div class="form-group">
                    <label asp-for="EventDate">Date &amp; time</label>
                    <input asp-for="EventDate" class="form-control" type="datetime-local" />
                    <p class="field-hint">Shown to participants exactly as entered.</p>
                    <span asp-validation-for="EventDate" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Capacity"></label>
                    <input asp-for="Capacity" class="form-control" min="1" placeholder="e.g. 100" />
                    <p class="field-hint">Total seats across all registrations.</p>
                    <span asp-validation-for="Capacity" class="field-error"></span>
                </div>
            </div>
        </div>

        <div class="form-section">
            <div class="form-section-head">
                <span class="form-section-eyebrow">03 — Assignments</span>
                <h2>Where &amp; what's on</h2>
            </div>
            <div class="form-row-2">
                <div class="form-group">
                    <label>Venues</label>
                    @{ var venueItems = (IEnumerable<SelectListItem>)ViewBag.Venues; }
                    @if (!venueItems.Any())
                    {
                        <p class="field-hint">No venues yet — <a asp-controller="Venues" asp-action="Create">create one first</a>.</p>
                    }
                    else
                    {
                        <div class="checkbox-chip-list">
                            @foreach (var item in venueItems)
                            {
                                <label class="checkbox-chip">
                                    <input type="checkbox" name="SelectedVenueIds" value="@item.Value" checked="@item.Selected" />
                                    <span>@item.Text</span>
                                </label>
                            }
                        </div>
                    }
                </div>
                <div class="form-group">
                    <label>Activities</label>
                    @{ var activityItems = (IEnumerable<SelectListItem>)ViewBag.Activities; }
                    @if (!activityItems.Any())
                    {
                        <p class="field-hint">No activities yet — <a asp-controller="Activities" asp-action="Create">create one first</a>.</p>
                    }
                    else
                    {
                        <div class="checkbox-chip-list">
                            @foreach (var item in activityItems)
                            {
                                <label class="checkbox-chip">
                                    <input type="checkbox" name="SelectedActivityIds" value="@item.Value" checked="@item.Selected" />
                                    <span>@item.Text</span>
                                </label>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="details-actions">
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="AdminIndex" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
