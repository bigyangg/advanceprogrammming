@model EventFormViewModel
@{
    ViewData["Title"] = "Create Event";
}

<link rel="stylesheet" href="~/css/events.css" asp-append-version="true" />

<div class="page-header">
    <span class="page-eyebrow">Admin</span>
    <h1>Create Event</h1>
    <p>Set the details, then assign the venues and activities that make it up.</p>
</div>

<div class="details-panel" style="max-width: 640px;">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="form-error-summary"></div>
        <div class="form-group mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="field-error"></span>
        </div>
        <div class="form-group mb-3">
            <label asp-for="EventDate" class="form-label"></label>
            <input asp-for="EventDate" class="form-control" type="datetime-local" />
            <span asp-validation-for="EventDate" class="field-error"></span>
        </div>
        <div class="form-group mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control"></textarea>
            <span asp-validation-for="Description" class="field-error"></span>
        </div>
        <div class="form-group mb-3">
            <label asp-for="Capacity" class="form-label"></label>
            <input asp-for="Capacity" class="form-control" />
            <span asp-validation-for="Capacity" class="field-error"></span>
        </div>
        <div class="form-group mb-3">
            <label class="form-label">Venues</label>
            <select asp-for="SelectedVenueIds" asp-items="ViewBag.Venues" class="form-select" multiple></select>
        </div>
        <div class="form-group mb-3">
            <label class="form-label">Activities</label>
            <select asp-for="SelectedActivityIds" asp-items="ViewBag.Activities" class="form-select" multiple></select>
        </div>
        <div class="details-actions" style="margin-top: 1.5rem;">
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="AdminIndex" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
