@model Event
@{
    ViewData["Title"] = "Event Details";
    int registered = Model.Registrations.Where(r => r.Status != RegistrationStatus.Cancelled).Sum(r => r.Seats);
    int capacity = Model.Capacity > 0 ? Model.Capacity : 1;
    int percentage = Math.Min(100, (int)((registered * 100) / capacity));
    int seatsLeft = Math.Max(0, capacity - registered);
}

<link rel="stylesheet" href="~/css/events.css" asp-append-version="true" />

<div class="page-header">
    <span class="page-eyebrow">Event</span>
    <h1>@Model.Name</h1>
    <p>@Model.EventDate.ToString("dddd, dd MMMM yyyy 'at' HH:mm")</p>
</div>

<div class="details-grid">
    <div class="details-panel">
        <h2>About this event</h2>
        <p class="description">@Model.Description</p>

        <div class="details-facts">
            <div>
                <div class="details-fact-label">Date &amp; time</div>
                <div class="details-fact-value">@Model.EventDate.ToString("dddd, dd MMMM yyyy HH:mm")</div>
            </div>
            <div>
                <div class="details-fact-label">Capacity &amp; registration</div>
                <div class="details-fact-value" style="margin-bottom: 0.5rem;">
                    <strong>@registered</strong> of <strong>@capacity</strong> registered
                </div>
                <div class="capacity-bar">
                    <div class="capacity-bar-fill" style="width: @(percentage)%;"></div>
                </div>
            </div>
        </div>

        <div class="details-actions">
            <a asp-action="Index" class="btn btn-outline-secondary">Back to events</a>
            @if (Context.Session.CurrentUserRole() == "Participant")
            {
                @if (seatsLeft > 0)
                {
                    <form asp-controller="Registrations" asp-action="Register" method="post" style="display: flex; gap: 0.5rem; align-items: center;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="eventId" value="@Model.EventId" />
                        <label for="seats-input" style="font-size: 0.9rem;">Seats</label>
                        <input id="seats-input" type="number" name="seats" value="1" min="1" max="@seatsLeft" class="form-control" style="width: 5rem;" />
                        <button type="submit" class="btn btn-primary">Book Event</button>
                    </form>
                }
                else
                {
                    <button type="button" class="btn btn-primary" disabled>Fully booked</button>
                }
            }
        </div>
    </div>

    <div>
        <div class="registry" style="margin-bottom: 1.5rem;">
            <p class="registry-heading">Venues (@Model.Venues.Count)</p>
            @if (Model.Venues.Count == 0)
            {
                <p class="registry-empty">No venues assigned yet.</p>
            }
            else
            {
                @foreach (var venue in Model.Venues)
                {
                    <div class="registry-entry">
                        <span class="registry-tag">Cap. @venue.Capacity</span>
                        <div class="registry-body">
                            <h3>@venue.Name</h3>
                            <p>@venue.Address</p>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="registry">
            <p class="registry-heading">Activities (@Model.Activities.Count)</p>
            @if (Model.Activities.Count == 0)
            {
                <p class="registry-empty">No activities assigned yet.</p>
            }
            else
            {
                @foreach (var activity in Model.Activities)
                {
                    <div class="registry-entry">
                        <span class="registry-tag">@activity.Type</span>
                        <div class="registry-body">
                            <h3>@activity.Name</h3>
                            <p>@activity.Description</p>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>
