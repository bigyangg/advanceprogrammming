@model EventIndexViewModel
@{
    ViewData["Title"] = "Upcoming Events";
}

<div class="container mt-4">
    <h2 class="mb-4">📅 Upcoming Events</h2>

    <!-- Filter Section -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form asp-action="Index" method="get">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label"><strong>Date</strong></label>
                        <input type="date" name="date" value="@(Model.Date?.ToString("yyyy-MM-dd"))" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label"><strong>Venue</strong></label>
                        <select name="venueId" class="form-select" asp-items="Model.Venues">
                            <option value="">-- All Venues --</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label"><strong>Activity</strong></label>
                        <select name="activityId" class="form-select" asp-items="Model.Activities">
                            <option value="">-- All Activities --</option>
                        </select>
                    </div>
                    <div class="col-md-3 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-primary w-100">🔍 Filter</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">↺ Reset</a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Events Grid -->
    @if (Model.Events.Count == 0)
    {
        <div class="alert alert-info text-center" role="alert">
            <h5>No events found.</h5>
            <p>Try adjusting your filters or check back later!</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model.Events)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm event-card hover-lift">
                        <!-- Event Image -->
                        <div class="position-relative overflow-hidden" style="height: 200px;">
                            <img src="@(item.ImagePath ?? "/images/events/img1_workshop.png")" 
                                 alt="@item.Name" 
                                 class="card-img-top img-fluid" 
                                 style="object-fit: cover; width: 100%; height: 100%;" />
                            <div class="position-absolute top-0 start-0 m-2">
                                <span class="badge bg-primary">@item.EventDate.ToString("dd MMM")</span>
                            </div>
                        </div>

                        <!-- Event Details -->
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@item.Name</h5>
                            <p class="card-text text-muted small">@item.Description</p>
                            
                            <!-- Event Meta -->
                            <div class="mb-3">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <span class="badge bg-light text-dark">📍 @item.Venues.Count venue(s)</span>
                                    <span class="badge bg-light text-dark">🎯 @item.Activities.Count activity(ies)</span>
                                </div>
                                <div class="progress mb-2" style="height: 20px;">
                                    @{
                                        int registered = item.Registrations.Count(r => r.Status != RegistrationStatus.Cancelled);
                                        int capacity = item.Capacity > 0 ? item.Capacity : 1;
                                        int percentage = (int)((registered * 100) / capacity);
                                    }
                                    <div class="progress-bar bg-success" role="progressbar" 
                                         style="width: @(percentage)%;" 
                                         aria-valuenow="@percentage" aria-valuemin="0" aria-valuemax="100">
                                        @registered / @capacity
                                    </div>
                                </div>
                            </div>

                            <!-- Action Buttons -->
                            <div class="d-grid gap-2 mt-auto">
                                <a asp-action="Details" asp-route-id="@item.EventId" class="btn btn-sm btn-outline-primary">
                                    👁️ View Details
                                </a>
                                @if (Context.Session.CurrentUserRole() == "Participant")
                                {
                                    <form asp-controller="Registrations" asp-action="Register" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="eventId" value="@item.EventId" />
                                        <button type="submit" class="btn btn-sm btn-success">
                                            ✅ Register Now
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .event-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .event-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
    }

    .hover-lift {
        cursor: pointer;
    }
</style>
