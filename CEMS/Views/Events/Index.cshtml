@model EventIndexViewModel
@{
    ViewData["Title"] = "Upcoming Events";
}

<!-- Link to new theme CSS -->
<link rel="stylesheet" href="~/css/cems-theme.css" />

<!-- Page Header -->
<div class="page-header">
    <div class="container">
        <h1>📅 Upcoming Events</h1>
        <p>Discover and register for amazing events happening near you</p>
    </div>
</div>

<div class="container" style="margin-top: var(--spacing-2xl);">
    
    <!-- Filters Section -->
    <div class="filter-card">
        <form asp-action="Index" method="get">
            <div class="filter-group">
                <div class="form-group-modern">
                    <label for="date-filter">📅 Event Date</label>
                    <input type="date" 
                           id="date-filter"
                           name="date" 
                           value="@(Model.Date?.ToString("yyyy-MM-dd"))" 
                           class="form-control" />
                </div>
                
                <div class="form-group-modern">
                    <label for="venue-filter">📍 Venue</label>
                    <select id="venue-filter" name="venueId" class="form-select" asp-items="Model.Venues">
                        <option value="">-- All Venues --</option>
                    </select>
                </div>
                
                <div class="form-group-modern">
                    <label for="activity-filter">🎯 Activity Type</label>
                    <select id="activity-filter" name="activityId" class="form-select" asp-items="Model.Activities">
                        <option value="">-- All Activities --</option>
                    </select>
                </div>
                
                <div class="filter-buttons">
                    <button type="submit" class="btn-primary-modern" style="flex: 1;">
                        🔍 Filter Events
                    </button>
                    <a asp-action="Index" class="btn-secondary-modern" style="flex: 1; text-align: center;">
                        ↺ Reset
                    </a>
                </div>
            </div>
        </form>
    </div>

    <!-- Events Section -->
    @if (Model.Events.Count() == 0)
    {
        <div class="empty-state animate-fade-in">
            <div class="empty-state-icon">📭</div>
            <h3>No events found</h3>
            <p>We couldn't find any events matching your filters. Try adjusting your search criteria or check back later for new events!</p>
            <a asp-action="Index" class="btn-primary-modern">Browse All Events</a>
        </div>
    }
    else
    {
        <div style="margin-bottom: var(--spacing-lg);">
            <p style="color: var(--text-muted); font-size: 0.95rem;">
                <strong>@Model.Events.Count()</strong> event(s) found
            </p>
        </div>

        <div class="grid-events">
            @foreach (var item in Model.Events)
            {
                <div class="event-card animate-fade-in">
                    <!-- Event Image Section -->
                    <div class="event-card-image">
                        <img src="@(item.ImagePath ?? "/images/events/img1_workshop.png")" 
                             alt="@item.Name" 
                             loading="lazy"
                             onerror="this.src='/images/events/img1_workshop.png'" />
                        <span class="event-card-badge date-badge">
                            @item.EventDate.ToString("dd MMM")
                        </span>
                    </div>

                    <!-- Card Body -->
                    <div class="event-card-body">
                        <!-- Title -->
                        <h3 class="event-card-title">@item.Name</h3>
                        
                        <!-- Description -->
                        <p class="event-card-description">@item.Description</p>
                        
                        <!-- Event Metadata -->
                        <div class="event-meta">
                            <div class="event-meta-item">
                                <span>📍</span>
                                <span class="event-meta-badge">
                                    @item.Venues.Count venue@(item.Venues.Count != 1 ? "s" : "")
                                </span>
                            </div>
                            <div class="event-meta-item">
                                <span>🎯</span>
                                <span class="event-meta-badge">
                                    @item.Activities.Count activit@(item.Activities.Count != 1 ? "ies" : "y")
                                </span>
                            </div>
                        </div>

                        <!-- Capacity Progress -->
                        <div class="event-capacity">
                            @{
                                int registered = item.Registrations.Count(r => r.Status != RegistrationStatus.Cancelled);
                                int capacity = item.Capacity > 0 ? item.Capacity : 1;
                                int percentage = (int)((registered * 100) / capacity);
                            }
                            <div class="capacity-label">
                                <span>👥 Registrations</span>
                                <span style="font-weight: 700; color: var(--text-dark);">
                                    @registered / @capacity
                                    <span style="color: var(--text-muted); font-weight: 500;">(@percentage%)</span>
                                </span>
                            </div>
                            <div class="progress-bar-custom">
                                <div class="progress-bar-fill" style="width: @(percentage)%;">
                                    @if (percentage > 10)
                                    {
                                        <span>@percentage%</span>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="event-actions">
                            <a asp-action="Details" 
                               asp-route-id="@item.EventId" 
                               class="btn-secondary-modern" 
                               style="text-align: center; padding: var(--spacing-sm) var(--spacing-md); font-size: 0.9rem;">
                                👁️ Details
                            </a>
                            @if (Context.Session.CurrentUserRole() == "Participant")
                            {
                                <form asp-controller="Registrations" 
                                      asp-action="Register" 
                                      method="post"
                                      style="display: contents;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="eventId" value="@item.EventId" />
                                    <button type="submit" 
                                            class="btn-success-modern"
                                            style="padding: var(--spacing-sm) var(--spacing-md); font-size: 0.9rem;">
                                        ✅ Register
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    /* Page-specific overrides */
    .filter-card {
        animation: fadeIn 0.3s ease-in-out;
    }

    .event-card {
        animation: fadeIn 0.4s ease-in-out;
    }

    /* Stagger animation for cards */
    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(15px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .event-card:nth-child(2) { animation-delay: 50ms; }
    .event-card:nth-child(3) { animation-delay: 100ms; }
    .event-card:nth-child(4) { animation-delay: 150ms; }
    .event-card:nth-child(5) { animation-delay: 200ms; }
    .event-card:nth-child(6) { animation-delay: 250ms; }
    .event-card:nth-child(n+7) { animation-delay: 300ms; }

    /* Loading state animation */
    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    .event-card.loading {
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
</style>

