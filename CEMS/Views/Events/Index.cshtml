@model EventIndexViewModel
@{
    ViewData["Title"] = "Upcoming Events";
}

<link rel="stylesheet" href="~/css/events.css" asp-append-version="true" />

<div class="page-header">
    <span class="page-eyebrow">Browse</span>
    <h1>Upcoming Events</h1>
    <p>Filter by date, venue or activity to find what's coming up.</p>
</div>

<div class="filter-bar">
    <form asp-action="Index" method="get">
        <div class="filter-bar-grid">
            <div class="filter-field">
                <label for="date-filter">Event date</label>
                <input type="date" id="date-filter" name="date" value="@(Model.Date?.ToString("yyyy-MM-dd"))" class="form-control" />
            </div>
            <div class="filter-field">
                <label for="venue-filter">Venue</label>
                <select id="venue-filter" name="venueId" class="form-select" asp-items="Model.Venues">
                    <option value="">All venues</option>
                </select>
            </div>
            <div class="filter-field">
                <label for="activity-filter">Activity type</label>
                <select id="activity-filter" name="activityId" class="form-select" asp-items="Model.Activities">
                    <option value="">All activities</option>
                </select>
            </div>
            <div class="filter-field filter-actions">
                <button type="submit" class="btn btn-primary">Filter</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
            </div>
        </div>
    </form>
</div>

@if (!Model.Events.Any())
{
    <div class="empty-state">
        <h3>No events found</h3>
        <p>Nothing matches these filters yet. Try adjusting them or check back later.</p>
        <a asp-action="Index" class="btn btn-primary">Browse all events</a>
    </div>
}
else
{
    <p class="results-count"><strong>@Model.Events.Count()</strong> event@(Model.Events.Count() != 1 ? "s" : "") found</p>

    <div class="event-grid">
        @foreach (var item in Model.Events)
        {
            int registered = item.Registrations.Count(r => r.Status != RegistrationStatus.Cancelled);
            int capacity = item.Capacity > 0 ? item.Capacity : 1;
            int percentage = Math.Min(100, (int)((registered * 100) / capacity));

            <div class="event-card">
                <div class="event-card-head">
                    <div class="date-stamp">
                        <span class="date-stamp-day">@item.EventDate.ToString("dd")</span>
                        <span class="date-stamp-month">@item.EventDate.ToString("MMM")</span>
                    </div>
                    <div>
                        <h3 class="event-card-title">@item.Name</h3>
                        <p class="event-card-desc">@item.Description</p>
                    </div>
                </div>

                <div class="event-card-meta">
                    <span class="meta-tag">@item.Venues.Count venue@(item.Venues.Count != 1 ? "s" : "")</span>
                    <span class="meta-tag">@item.Activities.Count activit@(item.Activities.Count != 1 ? "ies" : "y")</span>
                </div>

                <div class="event-card-capacity">
                    <div class="capacity-label">
                        <span>@registered / @capacity registered</span>
                        <span>@percentage%</span>
                    </div>
                    <div class="capacity-bar">
                        <div class="capacity-bar-fill" style="width: @(percentage)%;"></div>
                    </div>
                </div>

                <div class="event-card-actions">
                    <a asp-action="Details" asp-route-id="@item.EventId" class="btn btn-outline-secondary">Details</a>
                    @if (Context.Session.CurrentUserRole() == "Participant")
                    {
                        <form asp-controller="Registrations" asp-action="Register" method="post" style="display: contents;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="eventId" value="@item.EventId" />
                            <button type="submit" class="btn btn-primary">Register</button>
                        </form>
                    }
                </div>
            </div>
        }
    </div>
}
