@model Event
@{
    ViewData["Title"] = "Event Registrations";
    var registrations = Model.Registrations
        .OrderByDescending(r => r.RegistrationDate)
        .ToList();
}

<link rel="stylesheet" href="~/css/events.css" asp-append-version="true" />

<div class="page-header">
    <span class="page-eyebrow">Admin</span>
    <h1>Registrations &mdash; @Model.Name</h1>
    <p>@Model.EventDate.ToString("dddd, dd MMMM yyyy 'at' HH:mm")</p>
</div>

<div class="details-actions" style="margin-top: -1rem; margin-bottom: 1.5rem;">
    <a asp-action="AdminIndex" class="btn btn-outline-secondary">Back to admin events</a>
</div>

@if (registrations.Count == 0)
{
    <div class="empty-state">
        <h3>No registrations yet</h3>
        <p>Once participants book this event, they'll show up here.</p>
    </div>
}
else
{
    <div style="background: var(--panel); border: 1px solid var(--line); border-radius: var(--radius-md); overflow: hidden;">
        <table class="table" style="margin-bottom: 0;">
            <thead>
                <tr>
                    <th>Participant</th>
                    <th>Booked on</th>
                    <th>Seats</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in registrations)
                {
                    <tr>
                        <td>@item.Participant?.Name</td>
                        <td>@item.RegistrationDate.ToString("dd MMM yyyy, HH:mm")</td>
                        <td>@item.Seats</td>
                        <td>
                            @{
                                var pillClass = item.Status switch
                                {
                                    RegistrationStatus.Confirmed => "status-pill--confirmed",
                                    RegistrationStatus.Cancelled => "status-pill--cancelled",
                                    _ => "status-pill--pending",
                                };
                            }
                            <span class="status-pill @pillClass">@item.Status</span>
                        </td>
                        <td style="white-space: nowrap;">
                            @if (item.Status == RegistrationStatus.Pending)
                            {
                                <form asp-action="ConfirmRegistration" method="post" style="display: inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="registrationId" value="@item.RegistrationId" />
                                    <input type="hidden" name="eventId" value="@Model.EventId" />
                                    <button type="submit" class="btn btn-primary" style="font-size: 0.85rem; padding: 0.4rem 0.9rem;">Confirm</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
