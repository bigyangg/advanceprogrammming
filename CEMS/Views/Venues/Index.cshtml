@model IEnumerable<Venue>
@{
    ViewData["Title"] = "Venues";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Venues</h2>
    <a asp-action="Create" class="btn btn-primary">Create Venue</a>
</div>
<table class="table table-striped">
    <thead><tr><th>Name</th><th>Address</th><th>Capacity</th><th></th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Address</td>
            <td>@item.Capacity</td>
            <td class="d-flex gap-2">
                <a asp-action="Details" asp-route-id="@item.VenueId" class="btn btn-sm btn-outline-primary">Details</a>
                <a asp-action="Edit" asp-route-id="@item.VenueId" class="btn btn-sm btn-outline-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.VenueId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
